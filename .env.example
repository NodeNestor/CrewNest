# GitHub token for engineer repo access (push/pull to repos)
GITHUB_TOKEN=ghp_your_github_token_here

# CodeGate API key (from your CodeGate instance)
CODEGATE_API_KEY=

# Service URLs (defaults work if HiveMindDB/CodeGate run on the host)
# HIVEMINDDB_URL=http://host.docker.internal:8100
# CODEGATE_URL=http://host.docker.internal:9212

# Docker network name for engineer containers
# DOCKER_NETWORK=crewnest-network

# Default LLM model for the chat orchestrator
# DEFAULT_MODEL=claude-sonnet-4-20250514
